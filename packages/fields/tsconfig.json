{
  "include": ["src/**/*", "bin/**/*"],
  "compilerOptions": {
    "lib": ["ES2023"],
    "target": "ES2022",
    "module": "preserve",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],
    "noEmit": true,
    "ignoreDeprecations": "6.0",
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.tsbuildinfo",
    "paths": {
      "@fields-cms/fields": ["./src/plugin.ts"]
    }
  }
}
