{
  "extends": "@tsconfig/node24/tsconfig.json",
  "include": ["src/**/*", "bin/**/*"],
  "compilerOptions": {
    "module": "preserve",
    "moduleResolution": "bundler",
    "types": ["node"],
    "noEmit": true,
    "ignoreDeprecations": "6.0",
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.tsbuildinfo",
    "paths": {
      "fields": ["./src/plugin.ts"]
    }
  }
}
